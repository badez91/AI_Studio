APP_NAME=ai-studio
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
LOG_PATH=logs/ai-studio.log
DATABASE_URL=sqlite:///./ai_studio.db
CACHE_DIR=cache

# AI Provider: "auto" (tries Ollama, falls back to mock), "mock", or "ollama"
AI_PROVIDER=auto

# Ollama model to use (requires ollama serve running)
OLLAMA_MODEL=llama3.2
